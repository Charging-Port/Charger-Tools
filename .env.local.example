# Resend API key for contact form and newsletters
RESEND_API_KEY=re_your_api_key_here

# Email address to receive contact form submissions
CONTACT_EMAIL=kadenmac0077@gmail.com

# Base URL (used for metadata/SEO)
NEXT_PUBLIC_BASE_URL=https://chargertools.com

# Admin panel access — REQUIRED in production.
# If either is missing in NODE_ENV=production, admin login is disabled.
# - ADMIN_PASSWORD: the password you'll type on /admin/login. Use something long.
# - ADMIN_SECRET:   random string used to sign session cookies.
#   Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=changeme
ADMIN_SECRET=replace-me-with-a-long-random-string

# KV-backed content store — REQUIRED in production for inline-edit saves to persist.
# Vercel KV (Upstash Redis) auto-populates these when you provision the integration.
# If unset locally, the dev fallback at .dev-kv.json is used so the admin works
# out-of-the-box during development.
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your-token-here
